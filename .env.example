# Microsoft Clarity — Analytics e heatmaps (LGPD: só carrega após consentimento)
# Obter em: https://clarity.microsoft.com → seu projeto → Settings → Setup → "Get tracking code"
# Copiar apenas o ID (string alfanumérica ~10 chars), ex: "abc123xyz0"
NEXT_PUBLIC_CLARITY_PROJECT_ID=

# WhatsApp da equipe (somente dígitos: DDI + DDD + número)
NEXT_PUBLIC_WHATSAPP_VENDAS=5541999999999

# E-mail transacional (opcional — sem chave, salva preview em data/email-previews/)
RESEND_API_KEY=
LEADS_EMAIL_FROM=CampoAgro 2026 <onboarding@resend.dev>

# Google Sheets (Etapa 2 — leads da equipe comercial)
# Crie 3 abas na planilha com os cabeçalhos abaixo na linha 1:
#
# Aba "Expositores":
#   Data/Hora | Nome | E-mail | WhatsApp | Empresa | Mensagem | Origem | Status
#
# Aba "Patrocinadores":
#   Data/Hora | Nome | E-mail | WhatsApp | Empresa | Tipo Patrocínio | Mensagem | Origem | Status
#
# Aba "Compradores":
#   Data/Hora | Nome | E-mail | WhatsApp | Tipo Ingresso | Mensagem | Origem | Status
#
# Google Cloud: projeto + Sheets API ativa + Service Account + JSON da chave
# Compartilhe a planilha com o e-mail da service account (perfil Editor)
#
# Opção recomendada: salve o JSON da chave em credentials/google-service-account.json
# (copie de credentials/google-service-account.example.json e preencha com o arquivo do Google)
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=credentials/google-service-account.json
#
# Alternativa (menos legível): e-mail + chave direto no .env
# GOOGLE_SERVICE_ACCOUNT_EMAIL=
# GOOGLE_PRIVATE_KEY=
